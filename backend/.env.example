# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database (Railway PostgreSQL)
# Note: Railway provides DATABASE_URL automatically
# For local development, use:
DATABASE_URL=postgresql://user:password@localhost:5432/byhormiga
# Or configure individually:
DB_NAME=byhormiga
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Bucket (S3-compatible)
# Local development with MinIO (docker-compose)
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=byhormiga-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
